NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://blog:blog@localhost:5432/lorne_orbit
DATABASE_SSL=false

# Comma-separated exact frontend origins. Do not add a trailing slash.
FRONTEND_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

ADMIN_USERNAME=Lorne
# Generate with: npm run hash-password -- "your-long-password"
ADMIN_PASSWORD_HASH=$2b$12$replace_this_with_a_real_bcrypt_hash
JWT_SECRET=replace-with-at-least-32-random-characters

# Required only for image uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=lorne-orbit
